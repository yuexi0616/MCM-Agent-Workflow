        {
            "type": "equation",
            "bbox": [
                0.392,
                0.368,
                0.607,
                0.401
            ],
            "angle": 0,
            "content": "\\[\n\\cos \\gamma_ {s} = \\frac {\\sin \\delta - \\sin \\alpha_ {s} \\sin \\varphi}{\\cos \\alpha_ {s} \\cos \\varphi}\n\\]"
        },
        {
            "type": "text",
            "bbox": [
