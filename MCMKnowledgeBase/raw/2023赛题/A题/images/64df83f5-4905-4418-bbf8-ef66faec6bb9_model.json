        },
        {
            "type": "equation",
            "bbox": [
                0.374,
                0.48,
                0.622,
                0.511
            ],
            "angle": 0,
            "content": "\\[\n\\sin \\delta = \\sin \\frac {2 \\pi D}{3 6 5} \\sin \\left(\\frac {2 \\pi}{3 6 0} 2 3. 4 5\\right),\n\\]"
        },
        {
            "type": "text",
