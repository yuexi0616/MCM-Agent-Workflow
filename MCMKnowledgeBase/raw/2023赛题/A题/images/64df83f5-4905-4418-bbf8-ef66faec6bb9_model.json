                0.455
            ],
            "angle": 0,
            "content": "\\[\n\\omega = \\frac {\\pi}{1 2} (S T - 1 2),\n\\]"
        },
        {
            "type": "text",
            "bbox": [
                0.133,
                0.46,
                0.466,
                0.476
            ],
            "angle": 0,
            "content": null,
