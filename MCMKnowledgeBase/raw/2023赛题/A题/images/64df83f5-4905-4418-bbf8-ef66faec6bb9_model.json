            ],
            "angle": 0,
            "content": "\\[\n\\sin \\alpha_ {s} = \\cos \\delta \\cos \\varphi \\cos \\omega + \\sin \\delta \\sin \\varphi\n\\]"
        },
        {
            "type": "text",
            "bbox": [
                0.169,
                0.349,
