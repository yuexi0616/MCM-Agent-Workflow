                0.576,
                0.62,
                0.606
            ],
            "angle": 0,
            "content": "\\[\n\\mathrm{DNI} = G _ {0} \\left[ a + b \\exp \\left(- \\frac {c}{\\sin \\alpha_ {s}}\\right) \\right],\n\\]"
        },
